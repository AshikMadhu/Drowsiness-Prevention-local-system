# Driver Safety & Drowsiness Prevention System Environment Variables
# Copy this file to '.env' and modify settings for local overrides.

# Application Environment Mode (development / production)
APP_ENV=development

# Camera Source Configuration
# Use integer (e.g. 0) for default webcam, or string for path to video file
CAMERA_SOURCE=0
FRAME_WIDTH=640
FRAME_HEIGHT=480

# Logging Configurations
# Available levels: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
LOG_FILE_PATH=logs/driver_safety.log

# Persistence Database File Path
DATABASE_PATH=data/driver_safety.db

# Safety Algorithm Settings
CALIBRATION_FRAMES=100
EAR_THRESHOLD_DEFAULT=0.22
MAR_THRESHOLD_DEFAULT=0.50

# Audio Alert Configurations (1 = Enabled, 0 = Disabled)
AUDIO_ALARM_ENABLED=1
TTS_ENABLED=1
ALERT_VOLUME=0.8

# SMTP Email Alert Configuration (Required for Emergency Warnings & 4th repeat alarm)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_gmail_address@gmail.com
SMTP_PASSWORD=your_gmail_app_password
EMERGENCY_RECEIVER_EMAIL=ashiksjc2025@gmail.com

